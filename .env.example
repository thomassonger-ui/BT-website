# ---------------------------------------------------------------------------
# PUBLIC VARIABLES (NEXT_PUBLIC_*) — exposed to the browser. Never put secrets
# in a NEXT_PUBLIC_ variable.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_PHONE_NUMBER=
NEXT_PUBLIC_GENERAL_EMAIL=
NEXT_PUBLIC_PROPERTY_SEARCH_URL=
NEXT_PUBLIC_SCHEDULING_URL=
NEXT_PUBLIC_GOOGLE_MAPS_URL=
NEXT_PUBLIC_GOOGLE_BUSINESS_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_LINKEDIN_URL=

# ---------------------------------------------------------------------------
# SERVER-ONLY SECRETS — used only inside app/api/* route handlers and lib/.
# These are never bundled into client JavaScript. Do not prefix with
# NEXT_PUBLIC_. Do not commit real values.
# ---------------------------------------------------------------------------
LEAD_NOTIFICATION_EMAIL=
CONTACT_FORM_WEBHOOK_URL=
BUYER_LEAD_WEBHOOK_URL=
SELLER_LEAD_WEBHOOK_URL=
VALUATION_WEBHOOK_URL=
EMAIL_API_KEY=
